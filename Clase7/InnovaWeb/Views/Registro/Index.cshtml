@{
    ViewData["Title"] = "Registro de Equipo";
    ViewData["Subtitle"] = "Inscribe a tu equipo";
}

<div class="form-container glass">
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-error">@ViewBag.Error</div>
    }
    @if (ViewBag.Success != null)
    {
        <div class="alert alert-success">
            @ViewBag.Success
            <script>
                setTimeout(function() { window.location.href = '/'; }, 1500);
            </script>
        </div>
    }

    <form method="post" action="/Registro">
        <div class="form-group">
            <label for="teamName">Nombre del Equipo</label>
            <input type="text" id="teamName" name="teamName" class="form-control" required placeholder="Ej: Los Innovadores">
        </div>
        
        <div class="form-group">
            <label for="password">Contraseña</label>
            <input type="password" id="password" name="password" class="form-control" required placeholder="Ingresa tu contraseña">
        </div>
        
        <div class="form-group">
            <label for="passwordConfirm">Comprobación de Contraseña</label>
            <input type="password" id="passwordConfirm" name="passwordConfirm" class="form-control" required placeholder="Confirma tu contraseña">
        </div>

        <div class="form-group">
            <label for="numMembers">Número de integrantes (Máx 2)</label>
            <input type="number" id="numMembers" name="numMembers" class="form-control" min="1" max="2" required placeholder="Ej: 2">
        </div>

        <div class="form-group">
            <label for="membersNames">Nombres de Integrantes (separados por coma)</label>
            <input type="text" id="membersNames" name="membersNames" class="form-control" required placeholder="Ej: Juan Perez, Maria Gomez">
        </div>

        <button type="submit" class="btn btn-primary mt-1">Registrarse</button>
        <div class="text-center mt-1">
            <a href="/" style="color: var(--text-muted); text-decoration: none;">Volver al inicio</a>
        </div>
    </form>
</div>
