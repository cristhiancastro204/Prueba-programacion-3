@{
    ViewData["Title"] = "Inicio";
    ViewData["Subtitle"] = "El ecosistema donde nacen tus mejores ideas";
}

<div class="bento-grid">
    <!-- Register Action -->
    <a href="/Registro" class="bento-card bento-register">
        <div class="bento-icon">
            <!-- SVG User Edit -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M19 8l3 3-5 5-3-3 5-5z"></path>
            </svg>
        </div>
        <div>
            <h2>Inscribe tu Equipo</h2>
            <p>Comienza creando el núcleo de trabajo. Registra tu equipo con hasta 2 miembros.</p>
        </div>
    </a>

    <!-- Submit Action -->
    <a href="/Postulacion" class="bento-card bento-submit">
        <div class="bento-icon">
            <!-- SVG Lightbulb -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="9" y1="18" x2="15" y2="18"></line>
                <line x1="10" y1="22" x2="14" y2="22"></line>
                <path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"></path>
            </svg>
        </div>
        <div>
            <h2>Postular Proyecto</h2>
            <p>¿Tienen algo brillante? Postula las ideas usando las credenciales de tu equipo.</p>
        </div>
    </a>

    <!-- Professor Action -->
    <a href="/Profesor" class="bento-card bento-professor">
        <div class="bento-icon">
            <!-- SVG Shield / Lock -->
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#00f0ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
        </div>
        <div>
            <h2>Terminal del Profesor</h2>
            <p>Acceso administrativo clasificado para validación de ideas.</p>
        </div>
    </a>
</div>
